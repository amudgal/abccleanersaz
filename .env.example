# Admin credentials (generate hash with: node -e "require('bcryptjs').hash('yourpassword',10).then(h=>console.log(h))")
ADMIN_EMAIL=admin@abccleaners.com
ADMIN_PASSWORD_HASH=$2a$10$placeholder_hash_here

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=change-this-to-a-random-secret-key

# Google Places API Key (for real-time reviews)
# Enable "Places API (New)" in Google Cloud Console: https://console.cloud.google.com/apis/library/places.googleapis.com
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Site URL
NEXT_PUBLIC_SITE_URL=https://abccleaners.com
